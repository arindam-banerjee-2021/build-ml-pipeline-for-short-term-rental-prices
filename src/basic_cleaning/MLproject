name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_artifact:
        description: Fully-qualified name of the input artifact (e.g. sample.csv:latest)
        type: str
      output_artifact:
        description: Name for the output artifact (e.g. clean_sample.csv)
        type: str
      output_type:
        description: Type of the output artifact registered in W&B
        type: str
      output_description:
        description: A brief description of the output artifact
        type: str
      min_price:
        description: Minimum price (in USD) to keep. Rows below this are dropped.
        type: float
      max_price:
        description: Maximum price (in USD) to keep. Rows above this are dropped.
        type: float
    command: >-
      python run.py --input_artifact {input_artifact} \
                    --output_artifact {output_artifact} \
                    --output_type {output_type} \
                    --output_description {output_description} \
                    --min_price {min_price} \
                    --max_price {max_price}
