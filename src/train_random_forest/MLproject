name: train_random_forest
conda_env: conda.yml

entry_points:
  main:
    parameters:
      trainval_artifact:
        description: Train + validation dataset artifact from W&B
        type: str
      val_size:
        description: Fraction of the trainval set held out for validation
        type: float
      random_seed:
        description: Random seed for reproducibility
        type: int
        default: 42
      stratify_by:
        description: Column used to stratify the train/val split ("none" to disable)
        type: str
        default: "none"
      rf_config:
        description: Path to a JSON file with the Random Forest hyperparameters
        type: str
      max_tfidf_features:
        description: Maximum number of TF-IDF features to extract from the "name" column
        type: int
      output_artifact:
        description: Name for the exported model artifact
        type: str
    command: >-
      python run.py --trainval_artifact {trainval_artifact} \
                    --val_size {val_size} \
                    --random_seed {random_seed} \
                    --stratify_by {stratify_by} \
                    --rf_config {rf_config} \
                    --max_tfidf_features {max_tfidf_features} \
                    --output_artifact {output_artifact}
