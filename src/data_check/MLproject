name: data_check
conda_env: conda.yml

entry_points:
  main:
    parameters:
      csv:
        description: Fully-qualified name of the input artifact (e.g. clean_sample.csv:latest)
        type: str
      ref:
        description: Reference dataset artifact (e.g. clean_sample.csv:reference)
        type: str
      kl_threshold:
        description: Maximum Kullback-Leibler divergence allowed between reference and new distributions
        type: float
      min_price:
        description: Minimum allowed price
        type: float
      max_price:
        description: Maximum allowed price
        type: float
    command: >-
      pytest . -vv \
        --csv {csv} \
        --ref {ref} \
        --kl_threshold {kl_threshold} \
        --min_price {min_price} \
        --max_price {max_price}
